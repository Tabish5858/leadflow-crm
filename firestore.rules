rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: get workspace data (used in rules)
    function getWorkspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    // Helper: check if user is a workspace member
    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        getWorkspace(workspaceId).memberIds.hasAny([request.auth.uid]);
    }

    // Helper: check user role in workspace
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasRole(workspaceId, role) {
      return isWorkspaceMember(workspaceId) && getUserRole() == role;
    }

    // Users collection — users can only read/write their own doc
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // Workspaces — owner can do everything, members can read
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId) ||
        getWorkspace(workspaceId).ownerId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if getWorkspace(workspaceId).ownerId == request.auth.uid ||
        hasRole(workspaceId, 'admin');
      allow delete: if getWorkspace(workspaceId).ownerId == request.auth.uid;
    }

    // Leads — workspace members can read/create/update, owners/admins can delete
    match /leads/{leadId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Activities — workspace members can read/create, owners/admins can update/delete
    match /activities/{activityId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Tasks — workspace members can read/create/update, owners/admins can delete
    match /tasks/{taskId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId);
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Time entries — workspace members can read/create, owners can delete
    match /timeEntries/{entryId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create: if isWorkspaceMember(request.resource.data.workspaceId);
      allow update: if isWorkspaceMember(resource.data.workspaceId) &&
        resource.data.userId == request.auth.uid;
      allow delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Automations — workspace members can read, owners/admins can manage
    match /automations/{automationId} {
      allow read: if isWorkspaceMember(resource.data.workspaceId);
      allow create, update, delete: if hasRole(resource.data.workspaceId, 'admin') ||
        getWorkspace(resource.data.workspaceId).ownerId == request.auth.uid;
    }

    // Notifications — users can only read/write their own
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if true; // Created by Cloud Functions
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}

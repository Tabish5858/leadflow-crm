# Firebase (Client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase (Server - Admin SDK)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LeadFlow
NODE_ENV=development

# Email (Brevo - preferred, sends to any address)
RESEND_API_KEY=
FROM_EMAIL=your-verified-sender@yourdomain.com
FROM_NAME=LeadFlow CRM

# Email (Resend - alternative, requires domain verification)


# Cloudinary (Document Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_Project_ID=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

BREVO_API_KEY=

# Workspace Creation (comma-separated emails — only these can create workspaces)
NEXT_PUBLIC_ALLOWED_WORKSPACE_CREATORS=email1@example.com,email2@example.com

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
